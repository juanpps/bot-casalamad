{
  "name": "casalamad-bot",
  "version": "1.0.1",
  "description": "Panel Administrativo — Casa LAMAD WhatsApp Bot",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.casalamad.bot",
    "productName": "Casa LAMAD Bot",
    "copyright": "Copyright © 2025 Casa LAMAD",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/.git/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Casa LAMAD Bot",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "juanpps",
      "repo": "bot-casalamad",
      "private": false
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "auto-launch": "^5.0.6",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "nanoid": "^3.3.15",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
